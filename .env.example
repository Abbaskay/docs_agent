# --- Required ---
DEEPSEEK_API_KEY=sk-a34f4050b7974372ae3c6e06970949e0

# --- Server ---
PORT=5000
HOST=0.0.0.0
FLASK_DEBUG=0
FLASK_SECRET_KEY=
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=sqlite:///aidoc.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Redis (optional, falls back to in-memory) ---
REDIS_URL=

# --- CORS ---
ALLOWED_ORIGINS=*

# --- Rate Limiting: Anonymous Users ---
ANON_GENERATION_LIMIT=20
ANON_GENERATION_WINDOW=3600
ANON_EXPORT_LIMIT=10
ANON_EXPORT_WINDOW=3600

# --- Rate Limiting: Authenticated Users (set API_KEY to authenticate) ---
API_KEY=
AUTH_GENERATION_LIMIT=200
AUTH_GENERATION_WINDOW=86400
AUTH_EXPORT_LIMIT=100
AUTH_EXPORT_WINDOW=86400

# --- Upload Limits ---
UPLOAD_LIMIT=60
UPLOAD_WINDOW=3600
MAX_UPLOAD_SIZE_MB=50

# --- Document Limits ---
MAX_DOCUMENT_CHARS=100000
MAX_PROMPT_CHARS=100000

# --- DeepSeek ---
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- SocketIO ---
SOCKET_PING_TIMEOUT=60
SOCKET_PING_INTERVAL=25

# --- Cache ---
CACHE_DEFAULT_TTL=300
